<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="20sp"
        android:textColor="@android:color/black"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/trigger_anr_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trigger ANR (6s)"
        android:textSize="18sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/trigger_slow_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trigger Slow Operation (2s)"
        android:textSize="18sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_secondary"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/start_monitor_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start ANR Monitor"
        android:textSize="18sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_primary"
        android:textColor="@android:color/white"/>

    <Button
        android:id="@+id/stop_monitor_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Stop ANR Monitor"
        android:textSize="18sp"
        android:background="@color/gray"
        android:textColor="@android:color/white"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/gray"
        android:layout_marginVertical="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Classic ANR Scenarios"
        android:textSize="18sp"
        android:textColor="@android:color/black"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/network_main_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Network on Main Thread"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

    <Button
        android:id="@+id/db_main_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Database on Main Thread"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

    <Button
        android:id="@+id/deadlock_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Deadlock Demo"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

    <Button
        android:id="@+id/recursive_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Infinite Recursion"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

    <Button
        android:id="@+id/busy_loop_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Busy Loop"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

    <Button
        android:id="@+id/message_queue_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Message Queue Block"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

    <Button
        android:id="@+id/large_list_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Large List Processing"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        android:background="@color/design_default_color_error"/>

</LinearLayout>
